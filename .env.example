# ============================================
# OpenProject Rewrite — Environment Variables
# ============================================
# Copy this file to .env.local and fill in values

# --- Database ---
DATABASE_URL="postgresql://user:password@host:5432/openproject"

# --- Authentication ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"

# OAuth Providers (optional)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Redis Cache (Phase 6) ---
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token-here"

# --- Email (Phase 6) ---
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="noreply@example.com"
SMTP_PASSWORD="your-smtp-password"
EMAIL_FROM="OpenProject <noreply@example.com>"

# --- Error Tracking (Phase 6) ---
SENTRY_DSN="https://your-sentry-dsn@sentry.io/project"

# --- Data Migration (Phase 6) ---
OLD_OPENPROJECT_DATABASE_URL="postgresql://old_user:old_pass@old_host:5432/old_openproject"

# --- Optional ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
