// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// USER & AUTH
// ============================================

model User {
  id                        String   @id @default(cuid())
  email                     String   @unique
  name                      String
  passwordHash              String
  avatarUrl                 String?
  // L2/S2 FIX: isSystemAdmin for system-wide admin check (used by hard-delete endpoint)
  isSystemAdmin             Boolean  @default(false)
  // S2 FIX: passwordMigrationRequired — migrated users must reset password (old system used scrypt, new uses bcrypt)
  passwordMigrationRequired Boolean  @default(false)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  // Relations
  memberships              Member[]
  groupMemberships         GroupMembership[]
  assignedWPs              WorkPackage[]     @relation("Assignee")
  authorWPs                WorkPackage[]     @relation("Author")
  timeEntries              TimeEntry[]
  approvedTimeEntries      TimeEntry[]       @relation("TimeEntryApprover")
  // Phase 5 Sprint 2: per-user My Page layout (replaces the static-defaults stub)
  myPageLayout             MyPageLayout?
  // Wiki relations
  wikiPages                WikiPage[]
  wikiVersions             WikiPageVersion[]
  // Forum relations
  forums                   Forum[]
  forumThreads             ForumThread[]
  forumPosts               ForumPost[]
  forumVotes               ForumVote[]
  // Document relations
  documents                Document[]
  documentVersions         DocumentVersion[]
  // News relations (Phase 4)
  newsItems                News[]
  newsComments             NewsComment[]
  // Activity relations (Phase 4)
  activities               Activity[]
  activityCommentsReceived ActivityComment[] @relation("ActivityCommentAuthor")
  // Phase 5: Notification relations
  meetings                 Meeting[]
  meetingAttendees         MeetingAttendee[]
  meetingMinutes           MeetingMinutes[]

  // Phase 5: Notification relations
  notifications        Notification[]
  notificationSettings NotificationSetting[]

  // Phase 5: Watched work packages
  watchedWorkPackages WorkPackage[] @relation("WorkPackageWatchers")

  // Phase 6: File storage
  uploadedFiles ProjectFile[] @relation("FileUploader")

  // Phase 1.3: Two-Factor Authentication (TOTP)
  totpSecret          String? // Encrypted TOTP secret (stored encrypted at rest)
  totpEnabled         Boolean              @default(false)
  backupCodes         String? // JSON array of { hashedCode, plainCode, used }
  webAuthnCreds       String? // JSON array of WebAuthn credential data
  secondFactorPending String? // JSON: temporary storage during 2FA setup flow
  webAuthnCredentials WebAuthnCredential[]

  // API v3: Personal API key for OpenProject API compatibility
  apiKey String?

  // Phase 3: Invite Flow
  invitesAccepted Invite[] @relation("InviteAcceptedBy")
  invitesCreated  Invite[] @relation("InviteCreatedBy")

  @@map("users")
}

// ============================================
// PROJECT
// ============================================

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  identifier  String   @unique // URL-safe slug
  status      String   @default("active") // "active", "archived", "on_hold"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  members         Member[]
  workPackages    WorkPackage[]
  versions        Version[]
  sprints         Sprint[]
  modules         ProjectModule[]
  // Phase 4 relations
  wikiPages       WikiPage[]
  forums          Forum[]
  documents       Document[]
  documentFolders DocumentFolder[]
  meetings        Meeting[]
  newsItems       News[]
  activities      Activity[]

  // Phase 5: Project WIP Limits
  wipLimits ProjectWipLimit[]

  // Phase 6: File storage
  files ProjectFile[]

  // Phase 6: Git repositories
  repositories Repository[]

  // Phase 3: Invite Flow
  invites Invite[]

  // Phase 3: Deletion audit log
  deletionLogs ProjectDeletionLog[]

  // Phase 2: Budgets & Cost Tracking
  budgets Budget[]

  // Phase 5/6: Webhooks
  webhooks Webhook[]

  // Project Template reference
  generatedFrom String?

  @@map("projects")
}

model Member {
  id        String   @id @default(cuid())
  // Foreign keys
  userId    String
  projectId String
  roleId    String
  // Timestamps
  createdAt DateTime @default(now())

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role    Role    @relation(fields: [roleId], references: [id])

  @@unique([userId, projectId])
  @@map("members")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique // "Admin", "Member", "Viewer"
  permissions String[] // Stored as JSON string array; Phase 3 TypeScript casts to Permission[]

  members Member[]
  invites Invite[]

  @@map("roles")
}

// Phase 1.3: WebAuthn credentials
model WebAuthnCredential {
  id                  String    @id @default(cuid())
  userId              String
  credentialId        String    @unique
  credentialPublicKey String    @db.Text
  counter             Int       @default(0)
  deviceType          String?
  createdAt           DateTime  @default(now())
  lastUsedAt          DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("webauthn_credentials")
}

// ============================================
// WORK PACKAGES
// ============================================

model WorkPackage {
  id             String    @id @default(cuid())
  projectId      String
  subject        String
  description    String?
  statusId       String
  typeId         String
  priorityId     String // No default — must be set explicitly; use seeded "Normal" Priority ID
  assigneeId     String?
  authorId       String
  startDate      DateTime?
  dueDate        DateTime?
  estimatedHours Float?

  storyPoints Float?
  sprintId    String?
  position    Int      @default(0)
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  project     Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status      Status                @relation(fields: [statusId], references: [id])
  sprint      Sprint?               @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  type        Type                  @relation(fields: [typeId], references: [id])
  priority    Priority              @relation(fields: [priorityId], references: [id])
  assignee    User?                 @relation("Assignee", fields: [assigneeId], references: [id])
  author      User                  @relation("Author", fields: [authorId], references: [id])
  parent      WorkPackage?          @relation("ParentChild", fields: [parentId], references: [id])
  children    WorkPackage[]         @relation("ParentChild")
  relations   WorkPackageRelation[] @relation("RelationFrom")
  relationTo  WorkPackageRelation[] @relation("RelationTo")
  timeEntries TimeEntry[]
  watchers    User[]                @relation("WorkPackageWatchers")
  commitLinks CommitWorkPackage[]
  budgetLines BudgetLine[]

  @@index([projectId])
  @@index([statusId])
  @@index([assigneeId])
  // Phase 6 performance indexes
  @@index([projectId, statusId])
  @@index([projectId, assigneeId])
  @@index([projectId, typeId])
  @@index([dueDate])
  @@index([startDate])
  @@index([updatedAt])
  @@map("work_packages")
}

model Status {
  id       String  @id @default(cuid())
  name     String  @unique
  color    String  @default("#666")
  position Int     @default(0)
  isClosed Boolean @default(false)

  workPackages WorkPackage[]

  @@map("statuses")
}

model Type {
  id          String  @id @default(cuid())
  name        String  @unique // "Task", "Bug", "Feature", "Milestone"
  color       String  @default("#666")
  position    Int     @default(0)
  isMilestone Boolean @default(false)

  workPackages WorkPackage[]

  @@map("types")
}

model Priority {
  id       String @id @default(cuid())
  name     String @unique // "Low", "Normal", "High", "Urgent"
  color    String @default("#666")
  position Int    @default(0)

  workPackages WorkPackage[]

  @@map("priorities")
}

// ============================================
// RELATIONS
// ============================================

model WorkPackageRelation {
  id           String @id @default(cuid())
  fromId       String
  toId         String
  relationType String // "blocks", "blocked_by", "precedes", "follows", "relates"

  from WorkPackage @relation("RelationFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to   WorkPackage @relation("RelationTo", fields: [toId], references: [id], onDelete: Cascade)

  @@map("work_package_relations")
}

// ============================================
// SAVED QUERIES
// ============================================

model SavedQuery {
  id          String   @id @default(cuid())
  userId      String
  projectId   String?
  name        String
  filters     Json     @default("{}")
  sortBy      Json     @default("[]")
  groupBy     String?
  displayMode String   @default("table")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("saved_queries")
}

// ============================================
// TIME TRACKING (Phase 5, but schema here)
// ============================================

model TimeEntry {
  id            String   @id @default(cuid())
  workPackageId String
  userId        String
  hours         Float
  comment       String?
  // M1 FIX: store spentOn as UTC DateTime + user timezone for correct display
  spentOn       DateTime
  userTimezone  String   @default("UTC") // IANA timezone e.g. "Asia/Hong_Kong"

  // Approval workflow
  status       String    @default("pending") // pending | submitted | approved | rejected
  approvedBy   String?
  approvedAt   DateTime?
  rejectReason String?

  // Soft delete (M2: historical entries cannot be deleted)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workPackage WorkPackage @relation(fields: [workPackageId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id])
  approver    User?       @relation("TimeEntryApprover", fields: [approvedBy], references: [id])

  // Phase 6 performance indexes
  @@index([workPackageId, spentOn])
  @@index([userId, spentOn])
  @@map("time_entries")
}

// ============================================
// BUDGETS & COST TRACKING (Phase 2)
// ============================================

model Budget {
  id          String       @id @default(cuid())
  projectId   String
  name        String
  description String?
  amount      Float        @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  lines       BudgetLine[]
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("budgets")
}

model BudgetLine {
  id            String       @id @default(cuid())
  budgetId      String
  description   String
  unitCost      Float        @default(0)
  quantity      Float        @default(1)
  totalCost     Float        @default(0) // unitCost * quantity
  workPackageId String?
  createdAt     DateTime     @default(now())
  budget        Budget       @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  workPackage   WorkPackage? @relation(fields: [workPackageId], references: [id])

  @@index([budgetId])
  @@map("budget_lines")
}

// ============================================
// UNIFIED ACTIVITY FEED (Phase 4)
// Replaces old work-package-only Activity model
// ============================================

model Activity {
  id          String   @id @default(cuid())
  projectId   String
  userId      String
  // Polymorphic reference
  subjectType String // "work_package" | "wiki_page" | "forum_post" | "forum_thread" | "document" | "meeting" | "news" | "time_entry" | "member" | "version"
  subjectId   String // e.g. "wp-123", "wiki-api-docs", "doc-456"
  action      String // "created" | "updated" | "deleted" | "commented" | "viewed"
  details     Json? // { field: "status", oldValue: "open", newValue: "closed" }
  // @mentions — for auto-creating notifications
  mentionIds  String[] @default([])
  // Human-readable reference for display
  reference   Json // { type: "WorkPackage", id: "...", subject: "Fix login bug" }
  // Archive flag (after 2 years)
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())

  project  Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user     User              @relation(fields: [userId], references: [id])
  comments ActivityComment[]

  @@index([projectId, createdAt])
  @@index([projectId, isArchived])
  @@index([subjectType, subjectId])
  @@index([userId, createdAt])
  @@map("activities")
}

model ActivityComment {
  id         String   @id @default(cuid())
  activityId String
  userId     String
  content    String   @db.Text
  createdAt  DateTime @default(now())

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  author   User     @relation("ActivityCommentAuthor", fields: [userId], references: [id])

  @@map("activity_comments")
}

// ─────────────────────────────────────────────
// PROJECT WIP LIMITS
model ProjectWipLimit {
  id        String @id @default(cuid())
  projectId String
  statusId  String
  limit     Int? // null = no limit (unlimited)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, statusId])
  @@map("project_wip_limits")
}

model Query {
  id          String   @id @default(cuid())
  userId      String
  projectId   String?
  name        String
  filters     Json // WorkPackageFilter serialized
  sortBy      Json // SortBy[] serialized
  groupBy     String?
  displayMode String   @default("table") // "table" | "gantt" | "board" | "calendar"
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("queries")
}

// ============================================
// VERSIONS
// ============================================

model Version {
  id        String    @id @default(cuid())
  projectId String
  name      String
  status    String    @default("open") // "open", "closed"
  dueDate   DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("versions")
}

// ============================================
// PROJECT TEMPLATES
// ============================================

model ProjectTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  modules     String[] // module names to include
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// PROJECT MODULES (Phase 3)
// ============================================

model ProjectModule {
  id        String  @id @default(cuid())
  projectId String
  module    String // 'work_packages', 'gantt', 'board', 'calendar', 'wiki', 'forums', 'documents', 'meetings', 'time_tracking'
  enabled   Boolean @default(true)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, module])
  @@map("project_modules")
}

// ============================================
// WIKI (Phase 4)
// ============================================

model WikiPage {
  id        String   @id @default(cuid())
  projectId String
  title     String
  slug      String
  content   String   @db.Text
  parentId  String?
  authorId  String
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project  Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent   WikiPage?         @relation("WikiPageHierarchy", fields: [parentId], references: [id])
  children WikiPage[]        @relation("WikiPageHierarchy")
  author   User              @relation(fields: [authorId], references: [id])
  versions WikiPageVersion[]

  @@unique([projectId, slug])
  @@map("wiki_pages")
}

model WikiPageVersion {
  id         String   @id @default(cuid())
  wikiPageId String
  content    String   @db.Text
  authorId   String
  version    Int
  createdAt  DateTime @default(now())

  wikiPage WikiPage @relation(fields: [wikiPageId], references: [id], onDelete: Cascade)
  author   User     @relation(fields: [authorId], references: [id])

  @@index([wikiPageId])
  @@map("wiki_page_versions")
}

// ============================================
// FORUMS (Phase 4)
// ============================================

model Forum {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  description String?  @db.Text
  authorId    String
  createdAt   DateTime @default(now())

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author  User          @relation(fields: [authorId], references: [id])
  threads ForumThread[]

  @@map("forums")
}

model ForumThread {
  id        String   @id @default(cuid())
  forumId   String
  subject   String
  authorId  String
  isSticky  Boolean  @default(false)
  isPinned  Boolean  @default(false)
  isLocked  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  forum  Forum       @relation(fields: [forumId], references: [id], onDelete: Cascade)
  author User        @relation(fields: [authorId], references: [id])
  posts  ForumPost[]

  @@map("forum_threads")
}

model ForumPost {
  id        String   @id @default(cuid())
  threadId  String
  content   String   @db.Text
  authorId  String
  voteScore Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  thread ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author User        @relation(fields: [authorId], references: [id])
  votes  ForumVote[]

  @@map("forum_posts")
}

model ForumVote {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
  @@map("forum_votes")
}

// ============================================
// NEWS (Phase 4)
// ============================================

model News {
  id        String   @id @default(cuid())
  projectId String
  authorId  String
  title     String
  slug      String
  summary   String?  @db.VarChar(500)
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project  Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author   User          @relation(fields: [authorId], references: [id])
  comments NewsComment[]

  @@unique([projectId, slug])
  @@map("news")
}

model NewsComment {
  id        String   @id @default(cuid())
  newsId    String
  authorId  String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  news   News @relation(fields: [newsId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@map("news_comments")
}

// ============================================
// DOCUMENTS (Phase 4)
// ============================================

model Document {
  id          String    @id @default(cuid())
  projectId   String
  title       String
  description String?
  folderId    String?
  authorId    String
  // File metadata
  fileName    String    @default("")
  fileSize    Int       @default(0) // bytes
  fileType    String    @default("") // MIME type
  fileUrl     String    @default("") // storage URL (Phase 6: actual file URL)
  // Versioning
  version     Int       @default(1)
  // Soft delete (M2 FIX)
  deletedAt   DateTime?
  deletedBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project  Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author   User              @relation(fields: [authorId], references: [id])
  folder   DocumentFolder?   @relation(fields: [folderId], references: [id])
  versions DocumentVersion[]

  @@map("documents")
}

// DocumentVersion — each upload creates a new version
model DocumentVersion {
  id         String   @id @default(cuid())
  documentId String
  version    Int
  fileName   String
  fileSize   Int      @default(0)
  fileType   String   @default("")
  fileUrl    String   @default("")
  authorId   String
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  author   User     @relation(fields: [authorId], references: [id])

  @@unique([documentId, version])
  @@index([documentId])
  @@map("document_versions")
}

model DocumentFolder {
  id        String   @id @default(cuid())
  projectId String
  name      String
  parentId  String?
  createdAt DateTime @default(now())

  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent    DocumentFolder?  @relation("DocumentFolderHierarchy", fields: [parentId], references: [id])
  children  DocumentFolder[] @relation("DocumentFolderHierarchy")
  documents Document[]

  @@map("document_folders")
}

// ============================================
// MEETINGS (Phase 4)
// ============================================

model Meeting {
  id        String   @id @default(cuid())
  projectId String
  title     String
  startTime DateTime
  endTime   DateTime
  location  String?
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project   Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author    User                @relation(fields: [authorId], references: [id])
  attendees MeetingAttendee[]
  agenda    MeetingAgendaItem[]
  minutes   MeetingMinutes?

  @@map("meetings")
}

model MeetingAttendee {
  id        String  @id @default(cuid())
  meetingId String
  userId    String
  response  String  @default("none") // "none", "accepted", "declined"
  comment   String?

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([meetingId, userId])
  @@map("meeting_attendees")
}

model MeetingAgendaItem {
  id        String  @id @default(cuid())
  meetingId String
  title     String
  notes     String? @db.Text
  duration  Int? // minutes
  position  Int     @default(0)

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("meeting_agenda_items")
}

model MeetingMinutes {
  id        String   @id @default(cuid())
  meetingId String   @unique
  content   String   @db.Text
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id])

  @@map("meeting_minutes")
}

// ============================================
// NOTIFICATIONS (Phase 5)
// ============================================

model Notification {
  id              String    @id @default(cuid())
  userId          String
  reason          String // NotificationReason
  projectId       String
  projectName     String    @default("")
  resourceType    String // 'work_package', 'wiki_page', 'forum_thread', 'meeting', 'document'
  resourceId      String
  resourceSubject String    @default("")
  actorId         String
  actorName       String    @default("")
  read            Boolean   @default(false)
  readAt          DateTime?
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

model NotificationSetting {
  id               String  @id @default(cuid())
  userId           String
  projectId        String? // null = global settings
  notificationType String // e.g. 'work_package_assigned', 'mention'

  // D7 FIX: per-channel granular control
  emailEnabled  Boolean @default(true)
  inAppEnabled  Boolean @default(true)
  digestEnabled Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId, notificationType])
  @@map("notification_settings")
}

model EmailQueue {
  id          String    @id @default(cuid())
  to          String
  subject     String
  html        String
  attempts    Int       @default(0)
  lastError   String?
  scheduledAt DateTime
  processedAt DateTime?

  @@index([processedAt, scheduledAt, attempts])
  @@map("email_queue")
}

// ============================================
// FILE STORAGE (Phase 6)
// ============================================

model ProjectFile {
  id           String   @id @default(cuid())
  projectId    String
  filename     String
  storageKey   String   @unique
  contentType  String
  size         Int      @default(0)
  uploadedById String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation("FileUploader", fields: [uploadedById], references: [id])

  @@index([projectId])
  @@index([uploadedById])
  @@map("project_files")
}

// ============================================
// LDAP AUTHENTICATION (Phase 1.2)
// ============================================

model LdapServer {
  id             String   @id @default(cuid())
  name           String // Display name e.g. "Corporate AD"
  host           String // LDAP server hostname or IP
  port           Int      @default(389)
  useSsl         Boolean  @default(true)
  bindDn         String // Service account DN for searching
  bindPassword   String // Service account password (encrypted in production)
  baseDn         String // Base DN for user searches
  userFilter     String   @default("(objectClass=user)") // LDAP search filter for users
  emailAttribute String   @default("mail") // LDAP attribute for email
  nameAttribute  String   @default("cn") // LDAP attribute for display name
  groupFilter    String   @default("(objectClass=group)") // LDAP search filter for groups
  groupAttribute String   @default("member") // LDAP attribute for group membership
  enabled        Boolean  @default(true)
  autoSync       Boolean  @default(false) // Auto-sync users on login
  syncInterval   Int      @default(60) // Sync interval in minutes
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  mappings LdapGroupMapping[]

  @@map("ldap_servers")
}

model LdapGroupMapping {
  id            String   @id @default(cuid())
  ldapServerId  String
  ldapGroupDn   String // Full DN of the LDAP group
  ldapGroupName String // Display name of the LDAP group
  localRoleId   String // Our internal Role ID to assign
  createdAt     DateTime @default(now())

  ldapServer LdapServer @relation(fields: [ldapServerId], references: [id], onDelete: Cascade)

  @@unique([ldapServerId, ldapGroupDn])
  @@map("ldap_group_mappings")
}

// ============================================
// BACKLOGS — Sprint / Version management
// ============================================
model Sprint {
  id            String         @id @default(cuid())
  projectId     String
  name          String
  startDate     DateTime
  endDate       DateTime
  capacity      Float?
  velocity      Float?
  status        SprintStatus   @default(OPEN)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprintMembers SprintMember[]
  burndownData  BurndownData[]
  workPackages  WorkPackage[]

  @@index([projectId])
  @@map("sprints")
}

model SprintMember {
  id       String  @id @default(cuid())
  sprintId String
  userId   String
  capacity Float   @default(0)
  role     String?
  sprint   Sprint  @relation(fields: [sprintId], references: [id], onDelete: Cascade)

  @@unique([sprintId, userId])
  @@map("sprint_members")
}

model BurndownData {
  id        String   @id @default(cuid())
  sprintId  String
  date      DateTime
  remaining Float
  ideal     Float
  sprint    Sprint   @relation(fields: [sprintId], references: [id], onDelete: Cascade)

  @@unique([sprintId, date])
  @@index([sprintId])
  @@map("burndown_data")
}

enum SprintStatus {
  OPEN
  ACTIVE
  CLOSED
}

// ============================================
// CUSTOM FIELDS
// ============================================

model CustomField {
  id             String   @id @default(cuid())
  name           String
  fieldFormat    String // 'string' | 'int' | 'float' | 'bool' | 'date' | 'list' | 'user' | 'version'
  possibleValues String[] @default([]) // for list type
  defaultValue   String?
  required       Boolean  @default(false)
  searchable     Boolean  @default(false)
  filterable     Boolean  @default(false)
  editable       Boolean  @default(true)
  visible        Boolean  @default(true)
  entityType     String // 'WorkPackage' | 'Project' | 'User'
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("custom_fields")
}

// ============================================
// SETTINGS (Key-Value Store)
// ============================================

model Setting {
  key   String @id
  value String

  @@map("settings")
}

// ============================================
// REPOSITORIES (Phase 6)
// ============================================

model Repository {
  id        String   @id @default(cuid())
  projectId String
  type      String   @default("GIT") // GIT | SVN
  name      String
  url       String?
  localPath String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  commits Commit[]

  @@index([projectId])
  @@map("repositories")
}

model Commit {
  id           String   @id @default(cuid())
  repositoryId String
  sha          String   @unique
  message      String   @db.Text
  authorName   String
  authorEmail  String
  committedAt  DateTime
  createdAt    DateTime @default(now())

  repository   Repository          @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  workPackages CommitWorkPackage[]

  @@index([repositoryId])
  @@index([sha])
  @@map("commits")
}

model CommitWorkPackage {
  commitId      String
  workPackageId String

  commit      Commit      @relation(fields: [commitId], references: [id], onDelete: Cascade)
  workPackage WorkPackage @relation(fields: [workPackageId], references: [id], onDelete: Cascade)

  @@id([commitId, workPackageId])
  @@map("commit_work_packages")
}

// ============================================
// WEBHOOKS (Phase 5/6)
// ============================================

model Webhook {
  id         String            @id @default(cuid())
  projectId  String? // null = system-wide
  url        String
  secret     String? // HMAC secret
  events     String[] // ['work_package.created', 'work_package.updated', 'project.member_added']
  active     Boolean           @default(true)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  deliveries WebhookDelivery[]
  project    Project?          @relation(fields: [projectId], references: [id])
}

model WebhookDelivery {
  id           String    @id @default(cuid())
  webhookId    String
  event        String
  payload      String // JSON string
  status       String // 'pending' | 'success' | 'failed'
  responseCode Int?
  responseBody String?
  attempts     Int       @default(0)
  nextRetry    DateTime?
  createdAt    DateTime  @default(now())
  webhook      Webhook   @relation(fields: [webhookId], references: [id], onDelete: Cascade)
}

// ============================================
// ANNOUNCEMENTS (System-wide banners)
// ============================================

model Announcement {
  id          String    @id @default(cuid())
  content     String // markdown supported
  type        String    @default("info") // info | warning | success | error
  dismissible Boolean   @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ============================================
// USER GROUPS
// ============================================

model Group {
  id        String            @id @default(cuid())
  name      String            @unique
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  members   GroupMembership[]

  @@map("groups")
}

model GroupMembership {
  id      String   @id @default(cuid())
  groupId String
  userId  String
  addedAt DateTime @default(now())
  group   Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_memberships")
}

// ============================================
// BRANDING / WHITE-LABEL
// ============================================

model Branding {
  id           String   @id @default("default") // singleton
  logoUrl      String?
  faviconUrl   String?
  primaryColor String   @default("#1E40AF") // brand blue
  updatedAt    DateTime @updatedAt

  @@map("branding")
}

// ============================================
// PHASE 3: INVITE FLOW
// ============================================

model Invite {
  id         String    @id @default(cuid())
  email      String
  projectId  String
  roleId     String
  token      String    @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  userId     String? // Set when accepted
  invitedBy  String
  createdAt  DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User?   @relation("InviteAcceptedBy", fields: [userId], references: [id])
  inviter User    @relation("InviteCreatedBy", fields: [invitedBy], references: [id])
  role    Role    @relation(fields: [roleId], references: [id])

  @@index([projectId, acceptedAt])
  @@index([email])
  @@index([expiresAt])
  @@map("invites")
}

// D5 FIX: Tracks archive + delete actions for compliance / undo window
model ProjectDeletionLog {
  id          String   @id @default(cuid())
  projectId   String? // Optional so log survives project hard-delete (SetNull)
  projectName String // Snapshot — survives even when project is hard-deleted
  action      String // 'ARCHIVE' | 'DELETE' | 'HARD_DELETE'
  performedBy String
  reason      String?
  performedAt DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([performedBy])
  @@map("project_deletion_logs")
}

// Phase 5 Sprint 2: persisted "My Page" widget layout. One row per user
// (1:1 with User). Replaces the pre-existing static-defaults stub in
// pages/api/my-page/index.ts which always returned 4 hard-coded widgets.
//
// Storage shape: `widgets` is a JSON array of widget descriptors:
//   [{ id, type, config, position: {x,y,w,h}, collapsed }]
//
// Types in `types/my-page.ts` (WidgetType union). We use Json (not a child
// table) because the layout is opaque to the rest of the app — only the
// My Page page reads it back, and the structure is user-mutable.
model MyPageLayout {
  id        String   @id @default(cuid())
  userId    String   @unique
  widgets   Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("my_page_layouts")
}
