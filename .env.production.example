# =====================================================================
# OpenProject Rewrite — Production environment variables
# =====================================================================
# Copy to .env.production and fill in real values, then:
#   docker compose --env-file .env.production -f docker-compose.yml up -d
#
# DO NOT commit .env.production. .gitignore already excludes it.
#
# Generate secrets with: openssl rand -base64 32
# Or for hex: openssl rand -hex 32

# --- App port (host) → 3000 (container) ---
APP_PORT=3000

# --- Database (container-to-container in docker-compose) ---
# DATABASE_URL must match POSTGRES_USER / POSTGRES_PASSWORD below
DATABASE_URL=postgresql://oprw:<SET_ME>@db:5432/openproject
POSTGRES_USER=oprw
POSTGRES_PASSWORD=<SET_ME_db_password>
POSTGRES_DB=openproject

# --- Redis (container-to-container) ---
REDIS_URL=redis://redis:6379

# --- NextAuth (REQUIRED) ---
# NEXTAUTH_URL must match the URL the app is served from.
# Set this AFTER the reverse proxy is in place.
# For local testing before proxy, use http://localhost:3000
NEXTAUTH_URL=https://<your-domain.com>
NEXTAUTH_SECRET=<SET_ME_openssl_rand_-base64_32>
NEXTAUTH_TRUST_HOST=true

# --- Cron secret (REQUIRED) ---
# Required by /api/cron/process-email-queue
# If unset, cron endpoint refuses all calls (defence in depth)
CRON_SECRET=<SET_ME_openssl_rand_-base64_32>

# --- Email (SMTP) ---
SMTP_HOST=smtp.<your-mail-provider>.com
SMTP_PORT=587
SMTP_USER=noreply@<your-domain.com>
SMTP_PASSWORD=<SET_ME>
EMAIL_FROM=OpenProject <noreply@<your-domain.com>>

# --- Error tracking (Sentry, optional) ---
# If unset, Sentry is a no-op. To enable:
#   1. Create a Sentry project (sentry.io)
#   2. Copy the DSN to SENTRY_DSN
#   3. Set SENTRY_AUTH_TOKEN for source-map upload during build
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=<SET_ME>

# --- File storage (S3 optional, otherwise local) ---
# Leave S3_* empty to use local filesystem storage.
# Local storage persists in the app container; configure a Docker volume
# in production (or migrate to S3 for multi-host deployments).
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=<SET_ME>
S3_ENDPOINT=

# --- OAuth providers (optional) ---
# Leave empty to disable that provider on the login page.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=<SET_ME>
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=<SET_ME>

# --- Legacy migration (Phase 6, only if migrating from old OpenProject) ---
# OLD_OPENPROJECT_DATABASE_URL=postgresql://old_user:<SET_ME>@old_host:5432/old_openproject
